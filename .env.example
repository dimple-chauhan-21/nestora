# --- Ports (non-default: this machine already runs another project's stack on 5432/6379/9000-9001) ---
POSTGRES_PORT=5433
REDIS_PORT=6380
RABBITMQ_PORT=5673
RABBITMQ_MGMT_PORT=15673
MINIO_API_PORT=9002
MINIO_CONSOLE_PORT=9003

# --- Postgres ---
POSTGRES_USER=nestora
POSTGRES_PASSWORD=nestora
POSTGRES_DB=society_dev

# The running API's own connection — app_write_role, NOT the table-owning
# role above. app_write_role is a non-superuser, non-owner role created by
# infra/postgres-init/01-app-write-role.sql (automatic on a fresh
# `docker compose up`; run manually against an already-initialized volume —
# see README) specifically so Postgres Row-Level Security actually applies
# to the app's queries instead of being silently bypassed by table
# ownership. Table-level GRANTs for this role live in migration
# 1700000000019-AppWriteRoleGrants.ts.
DATABASE_URL=postgres://app_write_role:app_write_role_dev_password@localhost:5433/society_dev

# The migration CLI's (and seed script's) connection — deliberately the
# owning/admin role, deliberately separate from DATABASE_URL above.
# Migrations create tables and GRANT on them to app_write_role; a
# non-owner role can't do either. Never point the running app at this one.
MIGRATION_DATABASE_URL=postgres://nestora:nestora@localhost:5433/society_dev

# --- Redis ---
REDIS_URL=redis://localhost:6380

# --- RabbitMQ ---
RABBITMQ_USER=nestora
RABBITMQ_PASSWORD=nestora
RABBITMQ_URL=amqp://nestora:nestora@localhost:5673

# --- MinIO (S3-compatible local storage) ---
MINIO_ROOT_USER=nestora
MINIO_ROOT_PASSWORD=nestora123
S3_ENDPOINT=http://localhost:9002
S3_BUCKET=nestora-documents

# --- API ---
NODE_ENV=development
PORT=4000

# --- JWT (RS256) ---
# Local dev: generated by `pnpm --filter @nestora/api run keys:generate` into apps/api/keys/.
# Production: private key never touches disk/env directly — fetched at container
# boot from AWS Secrets Manager (secret: nestora/{env}/jwt-signing-key) into an
# in-memory-only path, public key can be distributed more freely for verification.
JWT_PRIVATE_KEY_PATH=keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=keys/jwt-public.pem
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30

# --- QR passes (HS256, Module 4) ---
# Same reasoning as JWT keys: dev-only fallback in code, real value from
# Secrets Manager in every real environment.
QR_TOKEN_SECRET=dev-only-qr-secret-do-not-use-in-prod

# --- Visitor approval escalation (Module 4) ---
VISIT_ESCALATION_WINDOW_SECONDS=300
GUARD_DASHBOARD_POLL_INTERVAL_SECONDS=15

# --- Payment gateway webhook (Module 4 billing) ---
# Same reasoning as JWT/QR secrets: dev-only fallback in code, real value from
# Secrets Manager in every real environment.
PAYMENT_GATEWAY_WEBHOOK_SECRET=dev-only-webhook-secret-do-not-use-in-prod

# --- Firebase Cloud Messaging (push notifications, Module 19) ---
# Unlike the secrets above, these have NO dev-only fallback — they default to
# empty string in code, and that emptiness is what NotificationModule checks
# to decide whether to bind the real FcmNotificationProvider or fall back to
# console-logging. Leave unset for local dev unless you're testing push for
# real; get real values from Firebase Console > Project Settings > Service
# Accounts > Generate new private key (downloads a JSON file — copy
# project_id, client_email, and private_key from it here).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

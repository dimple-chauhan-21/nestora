# Server-side only — deliberately NOT prefixed NEXT_PUBLIC_. apps/web never
# calls the backend directly from the browser; every request goes through a
# Next.js Route Handler (see src/app/api/) so the access/refresh tokens can
# live in an httpOnly cookie the client-side bundle can never read. This
# means the real backend URL/port also never needs to reach the client.
API_BASE_URL=http://localhost:4000

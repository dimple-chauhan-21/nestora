{
  "name": "@nestora/desktop",
  "version": "0.0.0",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "rebuild:native": "node scripts/rebuild-native.js",
    "dev": "npm run build && npm run rebuild:native && electron .",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nestora/types": "workspace:*",
    "@nestora/ui": "workspace:*",
    "better-sqlite3": "^12.11.1"
  },
  "devDependencies": {
    "@nestora/config": "workspace:*",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.16.0",
    "@types/react": "^18.3.0",
    "electron": "^39.8.10",
    "node-gyp": "^13.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.0",
    "eslint": "^9.15.0"
  }
}
